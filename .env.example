# Sanctuary - API Keys Configuration Example
#
# IMPORTANT:
# 1. Copy this file to .env (will be created gitignored)
# 2. Fill in your actual API keys
# 3. NEVER commit .env to git
# 4. NEVER share API keys in chat, email, or code
#
# Get API keys:
# - Groq (FREE, fast): https://console.groq.com/keys
# - Claude (PAID): https://console.anthropic.com/account/keys

# Groq API Key (Free tier - 5000+ requests/day)
# Used for testing and development
GROQ_API_KEY=gsk_YOUR_API_KEY_HERE

# Claude API Key (Paid - higher quality)
# Optional: only needed if switching to Claude provider
CLAUDE_API_KEY=sk_ant_YOUR_API_KEY_HERE

# AI Provider Selection
# Options: "groq" (default, free) or "claude" (premium)
AI_PROVIDER=groq
